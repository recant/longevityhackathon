# Ollama Cloud (https://ollama.com/settings/keys) — preferred for insights
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_HOST=https://ollama.com

# Anthropic Claude (preferred — used for insights + CV vision)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PARENT_PACE_DATA_DIR=

# Private shareable demo (HTTP Basic Auth on all routes except /api/health)
SHARE_USER=
SHARE_PASSWORD=
SHARE_REALM=Longevitree demo

# Comma-separated origins if using Vite dev against a remote API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
