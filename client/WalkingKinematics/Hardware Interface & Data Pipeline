import numpy as np
import time
from typing import List, Dict, Any, Optional

class AccelerometerSample:
    def __init__(self, timestamp: float, ax: float, ay: float, az: float, gps_speed: float):
        self.timestamp = timestamp
        self.ax = ax  # User acceleration X
        self.ay = ay  # User acceleration Y
        self.az = az  # User acceleration Z
        
        # 1. Calculate Linear Vector Magnitude
        self.linear_magnitude = np.sqrt(ax**2 + ay**2 + az**2)
        self.gps_speed = gps_speed

class MotionDataPipeline:
    def __init__(self, user_height_meters: float = 1.75):
        self.user_height = user_height_meters
        self.sample_buffer: List[AccelerometerSample] = []
        self.max_interval_speed = 0.0
        
        # Filter State & Coefficients
        self.filtered_z = 0.0
        self.alpha = 0.15  # Low-pass filter smoothing factory
        self.step_count = 0
        self.is_peak_flag = False
        
        # Session State
        self.start_time: Optional[float] = None
        self.total_distance_gps = 0.0
        self.last_gps_sample_time: Optional[float] = None

    def start_capture_session(self):
        self.start_time = time.time()
        self.sample_buffer.clear()
        self.max_interval_speed = 0.0
        self.step_count = 0
        self.total_distance_gps = 0.0

    def process_hardware_stream(self, timestamp: float, ax: float, ay: float, az: float, gps_speed: float):
        """
        Processes incoming 100Hz packets from telemetry files or live web sockets
        """
        # 2. Apply Real-Time Low-Pass Filter (LPF) on Z-Axis for step extraction
        self.filtered_z = (self.alpha * az) + ((1.0 - self.alpha) * self.filtered_z)
        self.detect_steps(self.filtered_z)
        
        # 3. Accumulate overall GPS Distance metrics
        if self.last_gps_sample_time is not None:
            time_delta = timestamp - self.last_gps_sample_time
            # Distance = speed * time
            self.total_distance_gps += gps_speed * time_delta
        self.last_gps_sample_time = timestamp

        # 4. Commit into high-speed Ring Buffer
        sample = AccelerometerSample(timestamp, ax, ay, az, gps_speed)
        self.sample_buffer.append(sample)
        
        # 5. Check 15-Second Windows
        self.evaluate_time_windows(current_timestamp=timestamp)