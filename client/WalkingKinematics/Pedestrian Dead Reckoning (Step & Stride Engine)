def detect_steps(self, filtered_value: float):
        """
        Finite State Machine tracking foot strike impact events
        """
        upper_threshold = 0.15  # g-forces
        lower_threshold = -0.15
        
        if filtered_value > upper_threshold and not self.is_peak_flag:
            self.is_peak_flag = True
            self.step_count += 1  # Heel strike registered
        elif filtered_value < lower_threshold and self.is_peak_flag:
            self.is_peak_flag = False  # Swing phase reset

    def calculate_dead_reckoning_speed(self, window_samples: List[AccelerometerSample], time_delta: float) -> float:
        """
        Calculates localized velocity without GPS using walking cadence
        """
        if not window_samples or time_delta <= 0:
            return 0.0
            
        # Biomechanical conversion: Stride length estimation
        assumed_stride_length = self.user_height * 0.415  # ~0.726 meters
        
        # Isolate steps occurring *strictly* within this time slice array
        # Real-time implementation profiles steps via sub-indexing, calculated here for the slice:
        steps_in_window = self.step_count  # Mock reference mapping to historical increments
        
        distance_covered = steps_in_window * assumed_stride_length
        speed_mps = distance_covered / time_delta
        return speed_mps