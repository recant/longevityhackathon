import tkinter as tk

class SimpleDesktopTimer:
    def __init__(self, root):
        self.root = root
        self.root.title("Timer")
        self.root.geometry("400x250")
        self.root.config(bg="#1e1e2e")  # Dark modern background
        
        # Internal state tracking
        self.elapsed_tenths = 0
        self.is_running = False
        self.timer_loop_job = None
        
        # Time Display Label
        self.label_display = tk.Label(
            self.root, 
            text="00:00.0", 
            font=("Helvetica", 48, "bold"), 
            fg="#cdd6f4", 
            bg="#1e1e2e"
        )
        self.label_display.pack(expand=True, pady=(20, 0))
        
        # Button Interface Layout Container
        self.button_frame = tk.Frame(self.root, bg="#1e1e2e")
        self.button_frame.pack(expand=True, fill=tk.X, pady=(0, 20))
        
        # Start Button
        self.btn_start = tk.Button(
            self.button_frame, 
            text="Start", 
            font=("Helvetica", 14, "bold"),
            bg="#a6e3a1", fg="#11111b",  # Green theme
            activebackground="#89b4fa",
            width=10, command=self.start_timer
        )
        self.btn_start.pack(side=tk.LEFT, expand=True, padx=10)
        
        # Stop Button
        self.btn_stop = tk.Button(
            self.button_frame, 
            text="Stop", 
            font=("Helvetica", 14, "bold"),
            bg="#f38ba8", fg="#11111b",  # Red/Coral theme
            activebackground="#89b4fa",
            width=10, command=self.stop_timer
        )
        self.btn_stop.pack(side=tk.LEFT, expand=True, padx=10)
        
        # Reset Button
        self.btn_reset = tk.Button(
            self.button_frame, 
            text="Reset", 
            font=("Helvetica", 14, "bold"),
            bg="#fab387", fg="#11111b",  # Orange theme
            activebackground="#89b4fa",
            width=10, command=self.reset_timer
        )
        self.btn_reset.pack(side=tk.LEFT, expand=True, padx=10)

    def update_loop(self):
        """Core execution loop updating state every 100 milliseconds."""
        if self.is_running:
            self.elapsed_tenths += 1
            self.format_and_render_time()
            # Schedule next increment execution thread loop in exactly 100ms
            self.timer_loop_job = self.root.after(100, self.update_loop)

    def format_and_render_time(self):
        """Converts total accumulated tenths of a second into standard MM:SS.d format."""
        minutes = (self.elapsed_tenths // 600)
        seconds = (self.elapsed_tenths // 10) % 60
        tenths = self.elapsed_tenths % 10
        
        time_string = f"{minutes:02d}:{seconds:02d}.{tenths}"
        self.label_display.config(text=time_string)

    def start_timer(self):
        """Engages loop execution state safely without overlapping active loop hooks."""
        if not self.is_running:
            self.is_running = True
            self.update_loop()

    def stop_timer(self):
        """Breaks execution sequence tracking loop safely."""
        if self.is_running:
            self.is_running = False
            if self.timer_loop_job:
                self.root.after_cancel(self.timer_loop_job)

    def reset_timer(self):
        """Halts running processing parameters and flushes values to zero baseline."""
        self.stop_timer()
        self.elapsed_tenths = 0
        self.label_display.config(text="00:00.0")

if __name__ == "__main__":
    app_window = tk.Tk()
    timer_instance = SimpleDesktopTimer(app_window)
    app_window.mainloop()